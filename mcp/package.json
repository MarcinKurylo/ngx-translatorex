{
  "name": "ngx-translatorex-mcp",
  "version": "0.1.0",
  "description": "MCP server to localize Angular / ngx-translate apps with an AI agent (Claude, Copilot): scan hard-coded strings, extract i18n keys, and translate — from any MCP client.",
  "license": "MIT",
  "author": "Marcin Kuryło",
  "homepage": "https://github.com/MarcinKurylo/ngx-translatorex/tree/main/mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MarcinKurylo/ngx-translatorex.git",
    "directory": "mcp"
  },
  "bugs": {
    "url": "https://github.com/MarcinKurylo/ngx-translatorex/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "i18n",
    "internationalization",
    "ngx-translate",
    "angular",
    "translation",
    "localization",
    "translate",
    "ai",
    "agent",
    "claude",
    "copilot",
    "llm"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "ngx-translatorex-mcp": "dist/mcp/src/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p ./",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^20.19.43"
  }
}
